# ── Mapbox ────────────────────────────────────────────────────────────────────
# Used for geocoding (address → lat/lng). Get yours at mapbox.com
MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# ── Google Maps Platform ───────────────────────────────────────────────────────
# Needs: Places API (New), Distance Matrix API, Geocoding API
# Get yours at console.cloud.google.com
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Real key from aistudio.google.com (not the placeholder). Whitespace is stripped.
# Card titles/scores are computed in Python; Gemini only writes threat-card bullets.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Optional: model name. Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
# Optional: seconds for Gemini request (default 90)
# GEMINI_TIMEOUT_SECONDS=90

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL and service role key (NOT the anon key)
# Get yours at supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ── OpenSky Network (optional) ────────────────────────────────────────────────
# Free account at opensky-network.org — increases rate limits
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── App Config ────────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:3000
